    "test:e2e": "playwright test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
